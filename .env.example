# Optional for demo mode. Without these, Railway still serves the app and auth
# falls back to local browser/device storage.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Optional integration endpoints. Leave blank until the backing services exist.
EXPO_PUBLIC_API_BASE_URL=
EXPO_PUBLIC_WEBHOOK_URL=
EXPO_PUBLIC_TRAINING_WEBHOOK_URL=
EXPO_PUBLIC_MESSAGE_WEBHOOK_URL=
EXPO_PUBLIC_WHATSAPP_PHONE_NUMBER_ID=

# --- Server-side only (agent runtime). NEVER prefix these with EXPO_PUBLIC_ ---
# Used by scripts/ (service role) and Supabase Edge Functions. Keep out of the
# client bundle. SUPABASE_URL / SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY are
# injected into deployed functions automatically.
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
# Optional: enables the cheap-model fallback (claude-haiku-4-5). Without it the
# runtime still works and uses a deterministic holding reply.
ANTHROPIC_API_KEY=
# Optional override for the fallback model id.
AGENT_MODEL=

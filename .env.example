# Optional for demo mode. Without these, Railway still serves the app and auth
# falls back to local browser/device storage.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Optional: native iOS StoreKit subscription product ids. These must match App
# Store Connect exactly before testing a development/App Store build.
EXPO_PUBLIC_STOREKIT_ANNUAL_PRODUCT_ID=nightime_annual
EXPO_PUBLIC_STOREKIT_MONTHLY_PRODUCT_ID=nightime_monthly
# Internal/demo escape hatch only. Keep false for production/App Store builds.
EXPO_PUBLIC_ALLOW_DEMO_ENTITLEMENT=false
# Opt-in dev bypass that skips the subscription paywall locally.
# Keep unset or false for normal testing.
EXPO_PUBLIC_BYPASS_PAYWALL=false
# Web currently grants a Supabase-backed web trial entitlement for launch testing.
# Replace with a real web checkout URL/flow before charging web users.

# --- Server-side only (agent runtime). NEVER prefix these with EXPO_PUBLIC_ ---
# Used by scripts/ (service role) and Supabase Edge Functions. Keep out of the
# client bundle. SUPABASE_URL / SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY are
# injected into deployed functions automatically.
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
# Optional: enables the cheap-model fallback (claude-haiku-4-5). Without it the
# runtime still works and uses a deterministic holding reply.
ANTHROPIC_API_KEY=
# Optional override for the fallback model id.
AGENT_MODEL=

# Optional: Google Voice over Gmail. Google Voice itself has no direct SMS API,
# so this watches Gmail notifications and replies through Gmail.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_PUBSUB_TOPIC=

# Optional: WhatsApp Cloud API. Store phone-number access tokens in
# agent_channels via scripts/connect-whatsapp.mjs; do not expose them to Expo.
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

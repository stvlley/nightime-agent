#!/usr/bin/env node

// Safely read specific keys from `.env` into process.env when present.
// This avoids loading client/public secrets into backend tooling.

const fs = require('fs');
const path = require('path');

const ENV_PATH = path.resolve('.env');

if (!fs.existsSync(ENV_PATH)) {
  process.exit(0);
}

const file = fs.readFileSync(ENV_PATH, 'utf8');

function setIfEmpty(key, raw) {
  const value = String(raw ?? '');
  if (!(key in process.env) || process.env[key] === '') {
    process.env[key] = value;
  }
}

for (const rawLine of file.split(/\r?\n/)) {
  const line = rawLine.trim();
  if (!line || line.startsWith('#') || !line.includes('=')) continue;
  const eq = line.indexOf('=');
  const key = line.slice(0, eq).trim();
  const value = line.slice(eq + 1).trim();
  for (const requested of process.argv.slice(2)) {
    if (requested === '--') break;
    if (key === requested) {
      setIfEmpty(key, value);
      break;
    }
  }
}

const sepIndex = process.argv.indexOf('--');
if (sepIndex >= 0 && sepIndex + 1 < process.argv.length) {
  const [cmd, ...args] = process.argv.slice(sepIndex + 1);
  const { spawn } = require('child_process');
  const child = spawn(cmd, args, { stdio: 'inherit', shell: false });
  child.on('exit', (code) => process.exitCode = code ?? 0);
}
